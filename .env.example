# ============================================
# ArcaneCodex 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 大多数变量有默认值，仅自定义部署时需要修改
# ============================================

# --- 数据库 ---
# SQLite 数据库路径（可选，默认为应用数据目录）
# Windows: %APPDATA%/ArcaneCodex/arcane_codex.db
# macOS: ~/Library/Application Support/com.arcanecodex.app/
# Linux: ~/.config/com.arcanecodex.app/
# DATABASE_PATH=

# --- AI 推理服务 ---
# 默认 AI 推理服务提供商（可选：lm_studio, ollama, hermes, openai, openrouter）
# 默认值: lm_studio
# DEFAULT_AI_PROVIDER=lm_studio

# LM Studio API 地址（本地模型推理）
# 默认值: http://127.0.0.1:1234
# LM_STUDIO_URL=http://127.0.0.1:1234

# Ollama API 地址（本地/远程 Ollama 服务）
# 默认值: http://127.0.0.1:11434
# OLLAMA_URL=http://127.0.0.1:11434

# Hermes One-Click API 地址（Agent 框架网关）
# 默认值: http://127.0.0.1:18789
# HERMES_URL=http://127.0.0.1:18789

# 默认 AI 模型名称（需与 Provider 匹配）
# LM Studio 示例: Qwen2.5-VL-7B-Instruct, Gemma-4-26B-A4B-it
# Ollama 示例: llava:7b, bakllava:7b
# OpenAI 示例: gpt-4o, gpt-4-turbo
# 默认值: Qwen2.5-VL-7B-Instruct
# DEFAULT_AI_MODEL=Qwen2.5-VL-7B-Instruct

# AI 推理超时时间（秒）
# 7B 模型可能较慢，建议 >= 60 秒
# 默认值: 60
# AI_TIMEOUT_SECS=60

# --- 任务队列 ---
# AI 任务队列并发数（同时处理的图片数量）
# 范围: 1-10，过高可能导致内存/OOM
# 默认值: 3
# AI_CONCURRENCY=3

# AI 任务队列容量（最大排队任务数）
# 默认值: 1000
# AI_QUEUE_CAPACITY=1000

# AI 任务最大重试次数（指数退避：2s → 4s → 8s）
# 默认值: 3
# AI_MAX_RETRIES=3

# --- 去重算法 ---
# pHash 相似度阈值（百分比，70-99）
# 90 = 高度相似视为重复（推荐）
# 70 = 宽松模式，可能误判
# 99 = 严格模式，仅完全相同
# 默认值: 90
# DEDUP_THRESHOLD=90

# pHash 算法位数（16/32/64/128/256）
# 64 位平衡精度与性能（推荐）
# 默认值: 64（硬编码，暂不支持修改）
# PHASH_BITS=64

# --- 日志系统 ---
# 日志级别（trace, debug, info, warn, error）
# 开发环境推荐: debug
# 生产环境推荐: info
# 默认值: info
# LOG_LEVEL=info

# --- 前端构建 ---
# Node.js 环境（development | production | test）
# 开发时自动设置为 development，无需手动修改
# NODE_ENV=development

# Vite 开发服务器端口（需与 tauri.conf.json 的 devUrl 一致）
# 默认值: 1420
# VITE_DEV_PORT=1420

# --- 安全相关 ---
# ⚠️ 以下变量仅供高级用户使用，错误配置可能导致数据丢失 ---

# 加密备份密码（用于 backup_database_encrypted 命令）
# 如果设置，备份将使用 AES-256-GCM + PBKDF2(600K iterations) 加密
# 不设置则生成未加密备份
# BACKUP_PASSWORD=

# API Key 加密盐值（可选，默认使用机器特征自动生成）
# ⚠️ 修改此值会导致已加密的 API Key 无法解密！
# ENCRYPTION_SALT=

# --- 云端 API 密钥 ---
# ⚠️ 安全提醒：切勿将真实密钥提交到版本控制！---
# OpenAI API Key（使用 OpenAI/OpenRouter Provider 时必需）
# OPENAI_API_KEY=sk-

# OpenRouter API Key（可选，也可使用 OPENAI_API_KEY）
# OPENROUTER_API_KEY=sk-or-

# 智谱 AI API Key（GLM-4-Flash 免费额度）
# ZHIPU_API_KEY=

# --- CSP 白名单（高级）---
# 如需连接额外的 AI 服务，需同步修改 tauri.conf.json 的 CSP 配置
# 格式: 协议://域名:端口
# CSP_EXTRA_CONNECT_SRC=
